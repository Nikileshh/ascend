# Copy this file to .env and fill in real values.
# .env is gitignored — never commit secrets.

PORT=4000
JWT_SECRET=change-me-to-a-long-random-string
# Public URL of the frontend — used for links inside emails.
# Production: your real domain, e.g. https://ascend.vercel.app
FRONTEND_URL=http://localhost:3000

# ── AI (Google Gemini) ───────────────────────────────────────────────
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3.1-flash-lite

# ── Email (Gmail SMTP) ───────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youraddress@gmail.com
SMTP_PASS=your-16-char-gmail-app-password
SMTP_FROM=Ascend <youraddress@gmail.com>

# ── Admin seed accounts ──────────────────────────────────────────────
ADMIN_EMAIL=admin@ascend.app
ADMIN_PASSWORD=change-me

# ── Premium billing (manual UPI / GPay QR) ───────────────────────────
UPI_ID=yourid@oksbi
UPI_NAME=Your Name
PREMIUM_PRICE=250

# ── Data persistence ─────────────────────────────────────────────────
# "file" (default)  = local db.json only (fine for a single server with a
#                     persistent disk).
# "supabase"        = also mirror the database to Supabase for durability
#                     (recommended when hosting). See DEPLOY.md.
STORE_DRIVER=file
# SUPABASE_URL=https://xxxxxxxx.supabase.co
# SUPABASE_KEY=your-service-role-key   # SERVICE ROLE key — keep secret

# Ollama (local AI) is no longer used — AI runs on Gemini above.
